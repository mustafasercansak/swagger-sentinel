{
	"name": "swagger-sentinel-workspace",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "npm run logo:versioned && npm run build --workspaces --if-present",
		"logo:versioned": "node scripts/generate-versioned-logo.mjs",
		"test": "npm run test --workspaces --if-present",
		"test:coverage": "npm run test:coverage --workspace packages/core",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"type-check": "npm run type-check:root && npm run type-check:workspaces",
		"type-check:root": "tsc -p tsconfig.typecheck.json --noEmit",
		"type-check:workspaces": "npm run type-check --workspaces --if-present"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"sharp": "^0.34.5"
	}
}
