{
	"name": "swagger-sentinel-vscode",
	"displayName": "Swagger Sentinel",
	"description": "Real-time OpenAPI 3.x validation, diagnostics and test generation for VS Code",
	"version": "1.1.0",
	"publisher": "mustafasercansak",
	"license": "MIT",
	"engines": {
		"vscode": "^1.95.0"
	},
	"categories": [
		"Linters",
		"Testing",
		"Other"
	],
	"keywords": [
		"openapi",
		"swagger",
		"validator",
		"api",
		"yaml"
	],
	"icon": "assets/logo.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/mustafasercansak/swagger-sentinel"
	},
	"activationEvents": [
		"onLanguage:yaml",
		"onLanguage:json"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "swagger-sentinel.validate",
				"title": "Validate Spec"
			},
			{
				"command": "swagger-sentinel.generateTests",
				"title": "Generate Tests"
			},
			{
				"command": "swagger-sentinel.clearDiagnostics",
				"title": "Clear Diagnostics"
			},
			{
				"command": "swagger-sentinel.enrich",
				"title": "AI Enrich Documentation"
			},
			{
				"command": "swagger-sentinel.setApiKey",
				"title": "Set AI API Key"
			},
			{
				"command": "swagger-sentinel.clearApiKey",
				"title": "Clear Stored AI API Keys"
			}
		],
		"configuration": {
			"title": "Swagger Sentinel",
			"properties": {
				"swagger-sentinel.autoValidate": {
					"type": "boolean",
					"default": true,
					"description": "Automatically validate OpenAPI spec on file save"
				},
				"swagger-sentinel.specPatterns": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"**/*api*.yaml",
						"**/*api*.yml",
						"**/*api*.json",
						"**/openapi*.yaml",
						"**/openapi*.yml",
						"**/swagger*.yaml",
						"**/swagger*.yml"
					],
					"description": "Glob patterns to identify OpenAPI spec files"
				},
				"swagger-sentinel.outputDir": {
					"type": "string",
					"default": "tests/generated",
					"description": "Output directory for generated test files"
				},
				"swagger-sentinel.ai.provider": {
					"type": "string",
					"enum": [
						"gemini",
						"openai"
					],
					"default": "gemini",
					"description": "AI provider for documentation enrichment"
				},
				"swagger-sentinel.ai.language": {
					"type": "string",
					"default": "en",
					"description": "Language for AI-generated documentation"
				}
			}
		},
		"menus": {
			"editor/context": [
				{
					"when": "resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json",
					"command": "swagger-sentinel.validate",
					"group": "swagger-sentinel"
				},
				{
					"when": "resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json",
					"command": "swagger-sentinel.generateTests",
					"group": "swagger-sentinel"
				},
				{
					"when": "resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json",
					"command": "swagger-sentinel.enrich",
					"group": "swagger-sentinel@1"
				},
				{
					"when": "resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json",
					"command": "swagger-sentinel.setApiKey",
					"group": "swagger-sentinel@2"
				},
				{
					"when": "resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json",
					"command": "swagger-sentinel.clearApiKey",
					"group": "swagger-sentinel@2"
				}
			]
		}
	},
	"dependencies": {},
	"scripts": {
		"build": "node -e \"require('fs').rmSync('dist/extension.js.map', { force: true })\" && esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --alias:swagger-sentinel=../core/src/index.ts --format=cjs --platform=node",
		"build:watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --alias:swagger-sentinel=../core/src/index.ts --format=cjs --platform=node --sourcemap --watch",
		"type-check": "tsc --noEmit",
		"package": "vsce package",
		"publish": "vsce publish"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/vscode": "^1.95.0",
		"esbuild": "^0.25.0",
		"typescript": "^6.0.3",
		"@vscode/vsce": "^3.0.0"
	}
}
