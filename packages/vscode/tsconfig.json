{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"moduleResolution": "Node10",
		"baseUrl": ".",
		"paths": {
			"swagger-sentinel": ["../core/src/index.ts"]
		},
		"ignoreDeprecations": "6.0",
		"outDir": "dist",
		"rootDir": "..",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": false,
		"lib": ["ES2022"],
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
